# 印尼智能催收系统 环境变量模板
# 复制为 .env，按需修改。.env 已加入 .gitignore 和 .dockerignore

# ── 基础 ──────────────────────────────────────────
ENV=development
API_PORT=8000

# ── 数据库 ────────────────────────────────────────
# SQLite（默认，适合测试）
DB_URI=sqlite:///./data/collection.db
# MySQL（生产）
# DB_URI=mysql+pymysql://user:password@host:3306/collection?charset=utf8mb4

# ── LLM ───────────────────────────────────────────
# mock / openai / anthropic / ollama
LLM_PROVIDER=mock
# OPENAI_API_KEY=sk-xxx
# LLM_API_KEY=xxx
# ANTHROPIC_AUTH_TOKEN=sk-ant-xxx
# OLLAMA_BASE_URL=http://localhost:11434

# ── ASR / TTS / 翻译（可选在线服务）───────────────
# ASR_API_KEY=xxx
# ASR_API_URL=https://asr-service/api
# TTS_API_KEY=xxx
# TTS_API_URL=https://tts-service/api
# TRANSLATE_API_KEY=xxx

# ── HuggingFace 模型缓存 ──────────────────────────
# 生产部署时 volume 挂载此目录避免重复下载模型
# HF_HOME=/app/.cache/huggingface

# ── 安全 ──────────────────────────────────────────
# API_SECRET_KEY=xxx
# JWT_SECRET_KEY=xxx
